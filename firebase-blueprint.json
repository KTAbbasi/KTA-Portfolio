{
  "entities": {
    "visitor": {
      "title": "Visitor",
      "description": "Unique visitor tracking information",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "country": { "type": "string" },
        "firstSeen": { "type": "string", "format": "date-time" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" }
      },
      "required": ["userId", "firstSeen"]
    },
    "view": {
      "title": "Page View",
      "description": "Tracking of individual page views and project interactions",
      "type": "object",
      "properties": {
        "visitorId": { "type": "string" },
        "page": { "type": "string" },
        "project": { "type": "string", "description": "Name of the project if applicable" },
        "timestamp": { "type": "string", "format": "date-time" },
        "duration": { "type": "number", "description": "Time spent in seconds" }
      },
      "required": ["visitorId", "page", "timestamp"]
    }
  },
  "firestore": {
    "analytics_events": {
      "schema": "analytics_event",
      "description": "Collection of all tracking events (page views, clicks, etc.)"
    }
  },
  "entities": {
    "analytics_event": {
      "title": "Analytics Event",
      "description": "A single tracking event",
      "type": "object",
      "properties": {
        "visitorId": { "type": "string" },
        "type": { "type": "string", "enum": ["page_view", "project_click", "session_end"] },
        "page": { "type": "string" },
        "project": { "type": "string" },
        "country": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" },
        "target": { "type": "string" },
        "ua": { "type": "string" }
      },
      "required": ["visitorId", "type", "timestamp"]
    }
  }
}
