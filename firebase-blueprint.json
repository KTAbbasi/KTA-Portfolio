{
  "entities": {
    "visitor": {
      "title": "Visitor",
      "description": "Unique visitor tracking information",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "country": { "type": "string" },
        "firstSeen": { "type": "string", "format": "date-time" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" }
      },
      "required": ["userId", "firstSeen"]
    },
    "analytics_event": {
      "title": "Analytics Event",
      "description": "A single tracking event (page view, project click, or session end)",
      "type": "object",
      "properties": {
        "visitorId": { "type": "string" },
        "type": { "type": "string", "enum": ["page_view", "project_click", "session_end"] },
        "url": { "type": "string" },
        "project": { "type": "string" },
        "country": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" },
        "target": { "type": "string" },
        "ua": { "type": "string" }
      },
      "required": ["visitorId", "type", "timestamp"]
    }
  },
  "firestore": {
    "analytics_events": {
      "schema": "analytics_event",
      "description": "Collection of all tracking events from site visitors"
    }
  }
}
